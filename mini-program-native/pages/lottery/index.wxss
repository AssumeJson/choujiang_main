.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F5 0%, #FFFFFF 100%);
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
  margin-top: 40rpx;
}

.titleRow {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  color: #FF6B6B;
  margin-left: 10rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #999;
}

.wheelContainer {
  display: flex;
  justify-content: center;
  margin-bottom: 60rpx;
  position: relative;
}

.wheel {
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 40rpx rgba(255, 107, 107, 0.4);
  position: relative;
  overflow: hidden;
}

.wheel::before {
  content: '';
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  right: 10rpx;
  bottom: 10rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.wheelInner {
  width: 360rpx;
  height: 360rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.wheelText {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

@keyframes spin {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(720deg);
  }
}

.btnSection {
  width: 100%;
  text-align: center;
}

.btnLottery {
  width: 100%;
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  box-shadow: 0 6rpx 20rpx rgba(255, 215, 0, 0.4);
}

.lotteryTip {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 20rpx;
}

.resultCard {
  width: 100%;
  background: #fff;
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  text-align: center;
}

.resultTitle {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  display: block;
  margin-bottom: 15rpx;
}

.resultPrize {
  font-size: 36rpx;
  font-weight: 600;
  color: #FF6B6B;
  display: block;
  margin-bottom: 40rpx;
}

.btnGroup {
  display: flex;
  gap: 20rpx;
}

.btnSecondary {
  flex: 1;
}

.btnPrimary {
  flex: 1;
}

.statusCard {
  width: 100%;
  background: #fff;
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  text-align: center;
}

.statusText {
  font-size: 32rpx;
  color: #666;
  display: block;
  margin-bottom: 40rpx;
}

.btnStatus {
  width: 100%;
}