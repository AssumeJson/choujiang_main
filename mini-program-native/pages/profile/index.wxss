.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F5 0%, #FFFFFF 100%);
  padding: 20rpx;
  padding-bottom: 180rpx;
}

.userInfo {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  text-align: center;
  margin-bottom: 20rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin: 0 auto 20rpx;
  overflow: hidden;
  border: 4rpx solid #FF6B6B;
}

.avatarImg {
  width: 100%;
  height: 100%;
  display: block;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.phone {
  font-size: 26rpx;
  color: #999;
  display: block;
}

.statsRow {
  display: flex;
  justify-content: center;
  gap: 60rpx;
  margin-top: 30rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid #f0f0f0;
}

.statItem {
  text-align: center;
}

.statNumber {
  font-size: 40rpx;
  font-weight: 700;
  color: #FF6B6B;
  display: block;
  margin-bottom: 8rpx;
}

.statLabel {
  font-size: 24rpx;
  color: #999;
}

.bindSection {
  margin-bottom: 20rpx;
}

.bindCard {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
}

.bindContent {
  flex: 1;
}

.bindTitle {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.bindDesc {
  font-size: 24rpx;
  color: #999;
}

.btnBind {
  flex-shrink: 0;
  width: 160rpx;
}

.menuSection {
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
  margin-bottom: 20rpx;
}

.menuItem {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menuItem:last-child {
  border-bottom: none;
}

.menuText {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.menuBadge {
  background: #FF6B6B;
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  margin-right: 15rpx;
}

.menuArrow {
  font-size: 32rpx;
  color: #ccc;
}

.logoutSection {
  padding-top: 20rpx;
}

.btnLogout {
  width: 100%;
}

.modalOverlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modalContent {
  width: 600rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
}

.modalTitle {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  display: block;
  text-align: center;
  margin-bottom: 15rpx;
}

.modalDesc {
  font-size: 26rpx;
  color: #999;
  display: block;
  text-align: center;
  margin-bottom: 30rpx;
}

.modalInput {
  width: 100%;
  height: 88rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  margin-bottom: 30rpx;
}

.modalBtnGroup {
  display: flex;
  gap: 20rpx;
}

.btnCancel {
  flex: 1;
}

.btnConfirm {
  flex: 1;
}