.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx;
  padding-top: 120rpx;
  box-sizing: border-box;
}

.header {
  text-align: center;
  margin-bottom: 80rpx;
}

.titleRow {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.title {
  font-size: 56rpx;
  font-weight: 700;
  color: #fff;
  margin-left: 15rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.loginForm {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
}

.formItem {
  margin-bottom: 30rpx;
}

.formLabel {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
  display: flex;
  align-items: center;
}

.formLabel text {
  margin-left: 8rpx;
}

.formInputWrapper {
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 0 20rpx;
}

.formInput {
  width: 100%;
  height: 80rpx;
  font-size: 28rpx;
  color: #333;
}

.btnWechat {
  width: 100%;
  background: #07c160;
  margin-bottom: 20rpx;
}

.btnPhone {
  width: 100%;
  background: #1989fa;
  margin-bottom: 30rpx;
}

.btnPrimary {
  width: 100%;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  margin-bottom: 20rpx;
}

.tipText {
  text-align: center;
  font-size: 22rpx;
  color: #999;
}

.guestLogin {
  margin-top: 40rpx;
  text-align: center;
}

.guestText {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.guestLink {
  font-size: 26rpx;
  color: #fff;
  margin-left: 10rpx;
  text-decoration: underline;
}
