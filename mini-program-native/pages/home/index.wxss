.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
  padding-bottom: 180rpx;
}

.header {
  text-align: center;
  padding: 40rpx 0;
}

.titleRow {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  color: #333;
  margin-left: 10rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #999;
}

.configCard {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.configHeader {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.configTitle {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

.statusTag {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  color: #fff;
}

.status0 {
  background: rgba(255, 255, 255, 0.3);
}

.status1 {
  background: #fff;
  color: #FF6B6B;
}

.status2 {
  background: #4CAF50;
}

.drawTime {
  margin-bottom: 10rpx;
  display: flex;
  align-items: center;
}

.drawLabel {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.drawValue {
  font-size: 26rpx;
  color: #fff;
  font-weight: 500;
}

.configDesc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
}

.statsCard {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.statsRow {
  display: flex;
  justify-content: space-around;
}

.statItem {
  text-align: center;
}

.statNumber {
  font-size: 48rpx;
  font-weight: 700;
  color: #FF6B6B;
  display: block;
}

.statLabel {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.section {
  margin-bottom: 30rpx;
}

.sectionTitle {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.actionCard {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.actionTitle {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.actionDesc {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 30rpx;
}

.btnPrimary {
  width: 100%;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
}

.rulesCard {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.ruleItem {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.ruleItem:last-child {
  margin-bottom: 0;
}

.ruleIndex {
  width: 40rpx;
  height: 40rpx;
  background: #FF6B6B;
  color: #fff;
  border-radius: 50%;
  font-size: 24rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.ruleText {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.btnRecords {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  color: #fff;
  border: none;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.btnRecords::after {
  border: none;
}
