.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
  padding-bottom: 180rpx;
}

.uploadArea {
  background: #fff;
  border-radius: 20rpx;
  padding: 80rpx 40rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 20rpx;
}

.uploadTitle {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 15rpx;
}

.uploadDesc {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 40rpx;
}

.btnUpload {
  width: 100%;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
}

.previewArea {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 20rpx;
}

.previewImage {
  width: 100%;
  height: 400rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.previewImg {
  width: 100%;
  height: 100%;
}

.recognizedInfo {
  padding: 20rpx;
}

.infoTitle {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.infoTitle text {
  margin-left: 10rpx;
}

.infoRow {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.infoLabel {
  font-size: 26rpx;
  color: #999;
}

.infoValue {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.btnGroup {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.btnSecondary {
  flex: 1;
}

.btnEdit {
  flex: 1;
}

.btnConfirm {
  flex: 2;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
}

.editForm {
  padding: 20rpx;
}

.formItem {
  margin-bottom: 25rpx;
}

.formLabel {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
  display: block;
}

.formInput {
  width: 100%;
  height: 80rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.tipsSection {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.tipsTitle {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.tipsTitle text {
  margin-left: 10rpx;
}

.tipsList {
  padding-left: 10rpx;
}

.tipItem {
  display: flex;
  align-items: flex-start;
  margin-bottom: 15rpx;
}

.tipItem:last-child {
  margin-bottom: 0;
}

.tipDot {
  width: 12rpx;
  height: 12rpx;
  background: #FF6B6B;
  border-radius: 50%;
  margin-right: 15rpx;
  margin-top: 12rpx;
  flex-shrink: 0;
}

.tipText {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}
