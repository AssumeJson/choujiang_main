.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F5 0%, #FFFFFF 100%);
  padding: 20rpx;
  padding-bottom: 180rpx;
}

.header {
  text-align: center;
  padding: 40rpx 0;
}

.titleRow {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  color: #333;
  margin-left: 10rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #999;
}

.configCard {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.configHeader {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.configName {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.statusTag {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.status0 {
  background: #f5f5f5;
  color: #999;
}

.status1 {
  background: #FFF3E0;
  color: #FF9800;
}

.status2 {
  background: #E8F5E9;
  color: #4CAF50;
}

.waitingInfo {
  padding-top: 10rpx;
  display: flex;
  align-items: center;
}

.waitingText {
  font-size: 26rpx;
  color: #666;
}

.waitingValue {
  font-size: 26rpx;
  color: #FF6B6B;
  font-weight: 500;
}

.waitingTip {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-top: 10rpx;
}

.emptyState {
  text-align: center;
  padding: 100rpx 0;
}

.emptyText {
  font-size: 32rpx;
  color: #666;
  display: block;
  margin-bottom: 10rpx;
}

.emptyTip {
  font-size: 26rpx;
  color: #999;
}

.recordsList {
  margin-top: 20rpx;
}

.listTitle {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.listTitle text {
  margin-left: 10rpx;
}

.recordCard {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
}

.recordContent {
  flex: 1;
}

.prizeName {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.recordTime {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 10rpx;
}

.claimedTag {
  font-size: 22rpx;
  color: #4CAF50;
  background: #E8F5E9;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
}

.unclaimedTag {
  font-size: 22rpx;
  color: #FF9800;
  background: #FFF3E0;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
}

.btnClaim {
  flex-shrink: 0;
  width: 140rpx;
}

.tipCard {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-top: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  text-align: center;
}

.tipTitle {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 15rpx;
}

.tipDesc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  display: block;
  margin-bottom: 30rpx;
}

.btnUpload {
  width: 100%;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
}